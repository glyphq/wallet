#!/usr/bin/env bash

# Self-detect APPDIR if the runtime didn't set it.
# $0 is the AppRun file itself, so its directory IS the AppDir root.
if [ -z "${APPDIR}" ]; then
  APPDIR="$(dirname "$(readlink -f "$0")")"
  export APPDIR
fi

# WebKitGTK subprocess helpers (WebKitNetworkProcess, WebKitWebProcess).
# linuxdeploy only bundles .so files — the executables must be pointed to
# explicitly or WebKit derives a garbage path (././/lib/...) and aborts.
export WEBKIT_EXEC_PATH="${APPDIR}/usr/lib/x86_64-linux-gnu/webkit2gtk-4.1"
export WEBKIT_DISABLE_COMPOSITING_MODE=1

# WebKitGTK 2.40+ introduced a DMA-BUF renderer that creates an EGL display
# before the apprun-hooks can force GDK_BACKEND=x11. This causes a hard abort
# ("Could not create default EGL display: EGL_BAD_PARAMETER") on many systems.
export WEBKIT_DISABLE_DMABUF_RENDERER=1

# Session D-Bus — not always inherited when launched from a file manager.
# Without this, zbus can't reach org.freedesktop.Notifications.
if [ -z "${DBUS_SESSION_BUS_ADDRESS}" ]; then
  _UID=$(id -u)
  if [ -S "/run/user/${_UID}/bus" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${_UID}/bus"
  elif [ -S "/run/user/${_UID}/dbus-session" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${_UID}/dbus-session"
  fi
fi

# Self-register on first run (and re-register if the AppImage has moved).
#
# Two things are required for glyph:// deep links to work:
#   1. A .desktop file in ~/.local/share/applications/ with the correct
#      Exec= pointing to THIS AppImage file (not the binary inside the
#      AppDir — that path only exists while the image is mounted).
#   2. glyph registered as the default x-scheme-handler via xdg-mime /
#      mimeapps.list; update-desktop-database alone only says "can handle",
#      it does not set the default that GNOME / KDE actually use.
#
# gtk-update-icon-cache is also required: without it the hicolor theme cache
# is stale and notify-rust sends notifications with no icon, which some
# daemons (GNOME, KDE) silently drop or misidentify.
_APPS="${HOME}/.local/share/applications"
_DESKTOP="${_APPS}/glyph.desktop"
_APPIMAGE_PATH="${APPIMAGE:-}"

# Detect if we need to (re-)register: missing desktop file OR Exec= points
# to a path that no longer matches the current AppImage location.
_NEEDS_REGISTER=0
if [ ! -f "${_DESKTOP}" ]; then
  _NEEDS_REGISTER=1
elif [ -n "${_APPIMAGE_PATH}" ]; then
  _CURRENT_EXEC=$(grep "^Exec=" "${_DESKTOP}" | head -1 | sed 's/^Exec=//;s/ %u$//')
  _CURRENT_EXEC="${_CURRENT_EXEC%\"}"
  _CURRENT_EXEC="${_CURRENT_EXEC#\"}"
  if [ "${_CURRENT_EXEC}" != "${_APPIMAGE_PATH}" ]; then
    _NEEDS_REGISTER=1
  fi
fi

if [ "${_NEEDS_REGISTER}" = "1" ]; then
  if [ "$(printf '%s' "${_APPIMAGE_PATH}" | wc -l)" -ne 0 ]; then
    echo "[glyph] AppImage path contains a newline; skipping desktop registration" >&2
    _NEEDS_REGISTER=0
  fi
fi

if [ "${_NEEDS_REGISTER}" = "1" ]; then
  mkdir -p "${_APPS}"
  _SRC=$(find "${APPDIR}" -maxdepth 1 -name "*.desktop" | head -1)
  if [ -n "${_SRC}" ]; then
    _ICON_NAME=$(awk -F= '$1 == "Icon" { print $2; exit }' "${_SRC}")
    [ -n "${_ICON_NAME}" ] || _ICON_NAME="Glyph"
    if [ -n "${_APPIMAGE_PATH}" ]; then
      # Rewrite Exec= to the AppImage file itself so the URL scheme handler
      # and app-menu launcher both work after the image is moved or renamed.
      # The sed program must keep $ and backticks literal.
      # shellcheck disable=SC2016
      _DESKTOP_PATH=$(printf '%s' "${_APPIMAGE_PATH}" | sed 's/\\/\\\\/g; s/"/\\"/g; s/`/\\`/g; s/\$/\\$/g')
      GLYPH_DESKTOP_EXEC="Exec=\"${_DESKTOP_PATH}\" %u" \
        awk '/^Exec=/ { print ENVIRON["GLYPH_DESKTOP_EXEC"]; next } { print }' \
        "${_SRC}" > "${_DESKTOP}"
    else
      cp "${_SRC}" "${_DESKTOP}"
    fi
  fi
  for _SIZE in 256x256 128x128; do
    _ICON=$(find "${APPDIR}/usr/share/icons" -name "*.png" -path "*/${_SIZE}/*" 2>/dev/null | head -1)
    if [ -n "${_ICON}" ]; then
      mkdir -p "${HOME}/.local/share/icons/hicolor/${_SIZE}/apps"
      cp "${_ICON}" "${HOME}/.local/share/icons/hicolor/${_SIZE}/apps/${_ICON_NAME}.png"
    fi
  done
  update-desktop-database "${_APPS}" 2>/dev/null || true
  gtk-update-icon-cache -f -t "${HOME}/.local/share/icons/hicolor" 2>/dev/null || true
  # Register as the default glyph:// handler. xdg-mime writes to
  # ~/.config/mimeapps.list which is what GNOME and KDE actually consult.
  xdg-mime default glyph.desktop x-scheme-handler/glyph 2>/dev/null || true
fi

# Source linuxdeploy apprun-hooks — these set GDK_BACKEND=x11, GTK_PATH,
# GDK_PIXBUF_MODULE_FILE, GIO_EXTRA_MODULES, GSETTINGS_SCHEMA_DIR, etc.
# Skipping them causes pixbuf loaders to fail, GTK themes to break, and
# Wayland EGL crashes. They must run before the app binary is exec'd.
# Hook paths are generated dynamically by linuxdeploy.
# shellcheck disable=SC1090
for _hook in "${APPDIR}/apprun-hooks/"*.sh; do
  [ -f "${_hook}" ] && source "${_hook}"
done

# Delegate to the original AppRun binary (linuxdeploy renamed it to .wrapped).
# It handles app-specific launch logic (chdir, Exec= lookup, etc.).
exec "${APPDIR}/AppRun.wrapped" "$@"
