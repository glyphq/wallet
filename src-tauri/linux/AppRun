#!/usr/bin/env bash

# Self-detect APPDIR if the runtime didn't set it.
# $0 is the AppRun file itself, so its directory IS the AppDir root.
# go-appimage's FUSE-free runtime should set APPDIR, but when it doesn't
# WEBKIT_EXEC_PATH expands to an empty prefix, WebKit falls back to its
# compiled-in path derivation, and produces a garbage path (././/lib/...).
if [ -z "${APPDIR}" ]; then
  APPDIR="$(dirname "$(readlink -f "$0")")"
  export APPDIR
fi

export WEBKIT_DISABLE_COMPOSITING_MODE=1

# WebKitGTK spawns helper processes (WebKitNetworkProcess, WebKitWebProcess).
# Without WEBKIT_EXEC_PATH it falls back to deriving the path from the executable
# name, which produces a garbage relative path (././/lib/...) and aborts.
# Without LD_LIBRARY_PATH the subprocess executables can't load their own libs.
export WEBKIT_EXEC_PATH="${APPDIR}/usr/lib/x86_64-linux-gnu/webkit2gtk-4.1"
export LD_LIBRARY_PATH="${APPDIR}/usr/lib:${APPDIR}/usr/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH}"

# Ensure the session D-Bus socket is reachable when the app is launched from a
# file manager or launcher that doesn't inherit the terminal's environment.
# Without this, zbus can't reach org.freedesktop.Notifications and desktop
# notifications fail silently (tauriSend returns void, errors are swallowed).
if [ -z "${DBUS_SESSION_BUS_ADDRESS}" ]; then
  _UID=$(id -u)
  if [ -S "/run/user/${_UID}/bus" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${_UID}/bus"
  fi
fi

# Self-register a local desktop entry + icon on first run.
# GNOME silently drops notifications from apps with no registered desktop entry.
_APPS="${HOME}/.local/share/applications"
_DESKTOP="${_APPS}/sigil.desktop"
if [ ! -f "${_DESKTOP}" ]; then
  mkdir -p "${_APPS}"
  _SRC=$(find "${APPDIR}" -maxdepth 1 -name "*.desktop" | head -1)
  [ -n "${_SRC}" ] && cp "${_SRC}" "${_DESKTOP}"
  _ICON=$(find "${APPDIR}/usr/share/icons" -name "*.png" -path "*/128x128/*" | head -1)
  if [ -n "${_ICON}" ]; then
    mkdir -p "${HOME}/.local/share/icons/hicolor/128x128/apps"
    cp "${_ICON}" "${HOME}/.local/share/icons/hicolor/128x128/apps/sigil.png"
  fi
  update-desktop-database "${_APPS}" 2>/dev/null || true
fi

exec "${APPDIR}/usr/bin/sigil-wallet" "$@"
