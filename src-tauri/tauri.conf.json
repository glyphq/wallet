{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glyph",
  "version": "0.14.2",
  "identifier": "com.qubic.glyph",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Glyph",
        "width": 380,
        "height": 680,
        "minWidth": 360,
        "minHeight": 640,
        "maxWidth": 420,
        "maxHeight": 760,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Glyph Ecosystem",
    "copyright": "© 2025 Glyph Ecosystem",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/icons/hicolor/128x128/apps/Glyph.png": "icons/128x128.png"
        }
      },
      "deb": {
        "depends": [
          "libdbus-1-3"
        ],
        "desktopTemplate": "linux/glyph.desktop.hbs"
      },
      "rpm": {
        "desktopTemplate": "linux/glyph.desktop.hbs"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "glyph"
        ]
      }
    },
    "updater": {
      "windows": {
        "installMode": "quiet"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCRjQzOUVERjAwNUJENDEKUldSQnZRWHc3VG4wSzNTbFlmcWtWSTFjV0NDS0xWaHFLNmdCT0lVelhmWHlYN1ZkTkVMdmZiREkK",
      "endpoints": [
        "https://github.com/glyph-ecosystem/wallet/releases/latest/download/latest.json"
      ]
    }
  }
}
