{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sigil",
  "version": "0.3.0",
  "identifier": "com.qubic.sigil",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sigil",
        "width": 380,
        "height": 680,
        "minWidth": 360,
        "minHeight": 640,
        "maxWidth": 420,
        "maxHeight": 760,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Qubic",
    "copyright": "© 2025 Qubic",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "sigil"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDMkI5NkEyODM2QjA1QTQKUldTa0JXdURvcFlySEh0SHB6d0FEaFI4azBrZTVGMmZhNTBhSzllU250NnZoZ1JRbHZ6bGRwVDMK",
      "endpoints": [
        "https://github.com/sigil-oss/sigil.app/releases/latest/download/latest.json"
      ]
    }
  }
}
